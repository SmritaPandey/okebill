# =============================================
# OkeBill — Environment Variables
# =============================================
# Copy this file to .env and fill in your values
# =============================================

# ── Frontend (Vite) ───────────────────────────
VITE_API_URL=http://localhost:4000

# ── OAuth (Frontend — Vite) ───────────────────
# Google: https://console.cloud.google.com/apis/credentials → OAuth 2.0 Client IDs
VITE_GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"

# Microsoft: https://portal.azure.com → App Registrations
VITE_MS_CLIENT_ID="your-microsoft-app-client-id"

# ── Supabase (legacy — optional) ──────────────
VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-supabase-anon-key"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"

# ── Database (Docker PostgreSQL) ──────────────
POSTGRES_DB=one_invoicer
POSTGRES_USER=oneinvoicer
POSTGRES_PASSWORD=oneinvoicer_secret
DB_PORT=5432

# ── Backend ───────────────────────────────────
JWT_SECRET=change-me-to-a-strong-random-secret
BACKEND_PORT=4000

# ── OAuth (Backend) ──────────────────────────
# Same Google Client ID as above — needed for server-side token verification
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"

# ── Frontend (Docker) ────────────────────────
FRONTEND_PORT=80
