// This is the Prisma schema file for Ok e Bill.
// It merges both the billing and core databases into a single unified schema.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth & Users ──────────────────────────────────────────

model User {
  id             Int       @id @default(autoincrement())
  email          String    @unique
  passwordHash   String    @map("password_hash")
  firstName      String    @map("first_name")
  lastName       String    @map("last_name")
  companyName    String    @map("company_name")
  role           String    @default("user")
  phone          String?   @unique
  phoneVerified  Boolean   @default(false) @map("phone_verified")
  emailVerified  Boolean   @default(false) @map("email_verified")
  onboardingComplete Boolean @default(false) @map("onboarding_complete")
  panNumber      String?   @map("pan_number")
  gstin          String?
  tan             String?   // Tax Deduction Account Number (10 chars)
  cin             String?   // Corporate Identification Number (21 chars)
  llpin           String?   // LLP Identification Number (7 chars)
  msmeUdyam       String?   @map("msme_udyam") // Udyam Registration Number
  fssaiLicense    String?   @map("fssai_license") // FSSAI 14-digit license
  iec             String?   // Import Export Code (10 chars = PAN)
  dpiitStartup    String?   @map("dpiit_startup") // DPIIT Startup Recognition
  companyType     String?   @map("company_type") // pvt_ltd, llp, proprietorship, partnership, opc, trust, ngo
  bankAccountNo  String?   @map("bank_account_no")
  bankIfsc       String?   @map("bank_ifsc")
  bankName       String?   @map("bank_name")
  bankBranch     String?   @map("bank_branch")
  upiId          String?   @map("upi_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  // Billing relations
  clients          Client[]
  proposals        Proposal[]
  contracts        Contract[]
  invoices         Invoice[]
  payments         Payment[]
  notifications    Notification[]
  settings         UserSettings[]
  files            File[]
  aiChatMessages   AiChatMessage[]
  subscriptions    Subscription[]
  paygTransactions PaygTransaction[]
  otpVerifications OtpVerification[]

  @@map("users")
}

// ─── Billing Module ────────────────────────────────────────

model Client {
  id                 Int       @id @default(autoincrement())
  userId             Int       @map("user_id")
  name               String
  contactEmail       String    @map("contact_email")
  phone              String?
  address            String?
  gstin              String?
  pan                String?   // Client's PAN
  tan                String?   // Client's TAN
  cin                String?   // Client's CIN
  llpin              String?   // Client's LLPIN
  msmeUdyam          String?   @map("msme_udyam")
  companyType        String?   @map("company_type")
  fssaiLicense       String?   @map("fssai_license")
  stateCode          String?   @map("state_code")
  billingPreferences Json?     @default("{}") @map("billing_preferences")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  proposals Proposal[]
  contracts Contract[]
  invoices  Invoice[]

  @@map("clients")
}

model Proposal {
  id        Int       @id @default(autoincrement())
  userId    Int       @map("user_id")
  clientId  Int       @map("client_id")
  title     String
  status    String    @default("draft")
  items     Json      @default("[]")
  total     Decimal   @default(0) @db.Decimal(12, 2)
  validUntil DateTime? @map("valid_until")
  notes     String?
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  client    Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  contracts Contract[]

  @@map("proposals")
}

model Contract {
  id           Int       @id @default(autoincrement())
  userId       Int       @map("user_id")
  clientId     Int       @map("client_id")
  proposalId   Int       @map("proposal_id")
  title        String
  status       String    @default("draft")
  terms        String?   @db.Text
  startDate    DateTime? @map("start_date")
  endDate      DateTime? @map("end_date")
  value        Decimal   @default(0) @db.Decimal(12, 2)
  billingCycle String?   @map("billing_cycle")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  client   Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  proposal Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  invoices Invoice[]

  @@map("contracts")
}

model Invoice {
  id              Int       @id @default(autoincrement())
  userId          Int       @map("user_id")
  clientId        Int       @map("client_id")
  contractId      Int?      @map("contract_id")
  invoiceNumber   String    @unique @map("invoice_number")
  status          String    @default("draft")
  items           Json      @default("[]")
  subtotal        Decimal   @default(0) @db.Decimal(12, 2)
  taxAmount       Decimal   @default(0) @map("tax_amount") @db.Decimal(12, 2)
  total           Decimal   @default(0) @db.Decimal(12, 2)
  placeOfSupply   String?   @map("place_of_supply")
  supplyType      String?   @default("intra") @map("supply_type")
  irn             String?   @map("irn")
  eInvoiceData    Json?     @map("e_invoice_data")
  // E-Way Bill fields
  ewayBillNumber  String?   @map("eway_bill_number")
  transportMode   String?   @map("transport_mode")
  vehicleNumber   String?   @map("vehicle_number")
  transporterName String?   @map("transporter_name")
  transporterGstin String?  @map("transporter_gstin")
  distanceKm      Int?      @map("distance_km")
  dueDate         DateTime  @map("due_date")
  issueDate       DateTime  @default(now()) @map("issue_date")
  sentAt          DateTime? @map("sent_at")
  paidDate        DateTime? @map("paid_date")
  notes           String?   @db.Text
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  client   Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  contract Contract? @relation(fields: [contractId], references: [id], onDelete: SetNull)
  payments Payment[]

  @@map("invoices")
}

model Payment {
  id            Int       @id @default(autoincrement())
  userId        Int       @map("user_id")
  invoiceId     Int       @map("invoice_id")
  amount        Decimal   @db.Decimal(12, 2)
  paymentMethod String    @map("payment_method")
  paymentDate   DateTime  @default(now()) @map("payment_date")
  reference     String?
  status        String    @default("completed")
  notes         String?   @db.Text
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("payments")
}

// ─── Commerce Module (Multi-tenant) ────────────────────────

model Tenant {
  id                 Int       @id @default(autoincrement())
  name               String
  subdomain          String    @unique
  industry           String
  currency           String    @default("USD") @db.VarChar(3)
  timezone           String    @default("UTC")
  financialYearStart DateTime? @map("financial_year_start")
  taxSettings        Json      @default("{}") @map("tax_settings")
  branding           Json      @default("{}") 
  settings           Json      @default("{}")
  status             String    @default("active")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  outlets      Outlet[]
  products     Product[]
  inventory    Inventory[]
  customers    Customer[]
  suppliers    Supplier[]
  transactions Transaction[]

  @@map("tenants")
}

model Outlet {
  id          Int      @id @default(autoincrement())
  tenantId    Int      @map("tenant_id")
  name        String
  code        String
  type        String   @default("store")
  address     Json     @default("{}")
  contactInfo Json     @default("{}") @map("contact_info")
  taxSettings Json     @default("{}") @map("tax_settings")
  posSettings Json     @default("{}") @map("pos_settings")
  status      String   @default("active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  inventory    Inventory[]
  transactions Transaction[]

  @@unique([tenantId, code])
  @@map("outlets")
}

model Product {
  id               Int      @id @default(autoincrement())
  tenantId         Int      @map("tenant_id")
  sku              String
  barcode          String?
  name             String
  description      String?  @db.Text
  category         String?
  brand            String?
  unit             String   @default("pcs")
  taxCategory      String?  @map("tax_category")
  hsnCode          String?  @map("hsn_code")
  productType      String   @default("goods") @map("product_type")
  industryMetadata Json?    @map("industry_metadata")
  pricing          Json?    @default("{}")
  trackingSettings Json?    @default("{}") @map("tracking_settings")
  status           String   @default("active")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  inventory        Inventory[]
  transactionItems TransactionItem[]

  @@unique([tenantId, sku])
  @@map("products")
}

model Inventory {
  id               Int       @id @default(autoincrement())
  tenantId         Int       @map("tenant_id")
  productId        Int       @map("product_id")
  outletId         Int       @map("outlet_id")
  batchNumber      String?   @map("batch_number")
  serialNumber     String?   @map("serial_number")
  expiryDate       DateTime? @map("expiry_date")
  quantity         Decimal   @default(0) @db.Decimal(15, 4)
  reservedQuantity Decimal   @default(0) @map("reserved_quantity") @db.Decimal(15, 4)
  costPrice        Decimal?  @map("cost_price") @db.Decimal(15, 4)
  sellingPrice     Decimal?  @map("selling_price") @db.Decimal(15, 4)
  location         String?
  status           String    @default("active")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  outlet  Outlet  @relation(fields: [outletId], references: [id], onDelete: Cascade)

  @@map("inventory")
}

model Customer {
  id               Int      @id @default(autoincrement())
  tenantId         Int      @map("tenant_id")
  customerCode     String?  @map("customer_code")
  name             String
  email            String?
  phone            String?
  address          Json     @default("{}") 
  taxInfo          Json     @default("{}") @map("tax_info")
  creditLimit      Decimal  @default(0) @map("credit_limit") @db.Decimal(15, 2)
  paymentTerms     Int      @default(0) @map("payment_terms")
  loyaltyPoints    Decimal  @default(0) @map("loyalty_points") @db.Decimal(10, 2)
  industryMetadata Json?    @map("industry_metadata")
  status           String   @default("active")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@unique([tenantId, customerCode])
  @@map("customers")
}

model Supplier {
  id           Int      @id @default(autoincrement())
  tenantId     Int      @map("tenant_id")
  supplierCode String?  @map("supplier_code")
  name         String
  email        String?
  phone        String?
  address      Json     @default("{}") 
  taxInfo      Json     @default("{}") @map("tax_info")
  paymentTerms Int      @default(30) @map("payment_terms")
  creditLimit  Decimal  @default(0) @map("credit_limit") @db.Decimal(15, 2)
  leadTimeDays Int      @default(7) @map("lead_time_days")
  status       String   @default("active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, supplierCode])
  @@map("suppliers")
}

model Transaction {
  id                Int       @id @default(autoincrement())
  tenantId          Int       @map("tenant_id")
  outletId          Int       @map("outlet_id")
  transactionNumber String    @map("transaction_number")
  transactionType   String    @map("transaction_type")
  customerId        Int?      @map("customer_id")
  subtotal          Decimal   @default(0) @db.Decimal(15, 2)
  taxAmount         Decimal   @default(0) @map("tax_amount") @db.Decimal(15, 2)
  discountAmount    Decimal   @default(0) @map("discount_amount") @db.Decimal(15, 2)
  totalAmount       Decimal   @default(0) @map("total_amount") @db.Decimal(15, 2)
  paymentStatus     String    @default("pending") @map("payment_status")
  paymentMethod     String?   @map("payment_method")
  paymentReference  String?   @map("payment_reference")
  notes             String?   @db.Text
  metadata          Json      @default("{}")
  status            String    @default("active")
  transactionDate   DateTime  @default(now()) @map("transaction_date")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  tenant   Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  outlet   Outlet            @relation(fields: [outletId], references: [id], onDelete: Cascade)
  customer Customer?         @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items    TransactionItem[]

  @@unique([tenantId, transactionNumber])
  @@map("transactions")
}

model TransactionItem {
  id             Int      @id @default(autoincrement())
  transactionId  Int      @map("transaction_id")
  productId      Int      @map("product_id")
  quantity       Decimal  @db.Decimal(15, 4)
  unitPrice      Decimal  @map("unit_price") @db.Decimal(15, 4)
  discountAmount Decimal  @default(0) @map("discount_amount") @db.Decimal(15, 2)
  taxAmount      Decimal  @default(0) @map("tax_amount") @db.Decimal(15, 2)
  lineTotal      Decimal  @map("line_total") @db.Decimal(15, 2)
  batchNumber    String?  @map("batch_number")
  serialNumber   String?  @map("serial_number")
  notes          String?  @db.Text
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now()) @map("created_at")

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  product     Product     @relation(fields: [productId], references: [id])

  @@map("transaction_items")
}

// ─── Support Models ────────────────────────────────────────

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  type      String
  title     String
  message   String   @db.Text
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model UserSettings {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  category  String
  settings  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category])
  @@map("user_settings")
}

model File {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  fileName    String   @map("file_name")
  filePath    String   @map("file_path")
  fileSize    Int      @map("file_size")
  contentType String   @map("content_type")
  entityType  String?  @map("entity_type")
  entityId    Int?     @map("entity_id")
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("files")
}

// ─── Recurring Invoices ────────────────────────────────────

model RecurringInvoice {
  id              Int       @id @default(autoincrement())
  userId          Int       @map("user_id")
  clientId        Int       @map("client_id")
  templateItems   Json      @default("[]") @map("template_items")
  subtotal        Decimal   @default(0) @db.Decimal(12, 2)
  taxRate         Decimal   @default(0) @map("tax_rate") @db.Decimal(5, 2)
  total           Decimal   @default(0) @db.Decimal(12, 2)
  frequency       String    @default("monthly") // weekly, monthly, quarterly, yearly
  nextDate        DateTime  @map("next_date")
  endDate         DateTime? @map("end_date")
  paymentTermsDays Int      @default(30) @map("payment_terms_days")
  notes           String?   @db.Text
  active          Boolean   @default(true)
  lastGeneratedAt DateTime? @map("last_generated_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@map("recurring_invoices")
}

// ─── Email Tracking ────────────────────────────────────────

model EmailLog {
  id          Int       @id @default(autoincrement())
  userId      Int       @map("user_id")
  toEmail     String    @map("to_email")
  subject     String
  entityType  String    @map("entity_type") // invoice, proposal, reminder
  entityId    Int       @map("entity_id")
  status      String    @default("sent") // sent, delivered, failed
  sentAt      DateTime  @default(now()) @map("sent_at")

  @@map("email_logs")
}

// ─── AI Chat History ───────────────────────────────────────

model AiChatMessage {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  role      String   // user, assistant, system
  content   String   @db.Text
  action    Json?    // structured action result (e.g. { type: 'createInvoice', data: {...} })
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("ai_chat_messages")
}

// ─── Subscription & Billing ───────────────────────────────

model Subscription {
  id              Int       @id @default(autoincrement())
  userId          Int       @map("user_id")
  plan            String    @default("free_trial") // free_trial, starter, professional, enterprise
  status          String    @default("active")     // active, expired, cancelled, past_due
  startDate       DateTime  @default(now()) @map("start_date")
  endDate         DateTime? @map("end_date")
  trialEndsAt     DateTime? @map("trial_ends_at")
  amount          Decimal   @default(0) @db.Decimal(12, 2)
  currency        String    @default("INR") @db.VarChar(3)
  paygOrderKeyId  String?   @map("payg_order_key_id")
  lastPaymentAt   DateTime? @map("last_payment_at")
  cancelledAt     DateTime? @map("cancelled_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model PaygTransaction {
  id                   Int       @id @default(autoincrement())
  userId               Int       @map("user_id")
  orderKeyId           String    @map("order_key_id")
  uniqueRequestId      String    @unique @map("unique_request_id")
  orderAmount          Decimal   @db.Decimal(12, 2) @map("order_amount")
  orderStatus          String?   @map("order_status")
  paymentStatus        Int       @default(0) @map("payment_status")
  paymentMethod        String?   @map("payment_method")
  paymentTransactionId String?   @map("payment_transaction_id")
  paymentResponseCode  Int       @default(0) @map("payment_response_code")
  paymentResponseText  String?   @map("payment_response_text")
  paymentProcessUrl    String?   @map("payment_process_url") @db.Text
  purpose              String    @default("subscription") // subscription, invoice_payment
  entityId             Int?      @map("entity_id") // e.g. invoiceId for invoice payments
  rawResponse          Json?     @map("raw_response")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("payg_transactions")
}

model OtpVerification {
  id         Int       @id @default(autoincrement())
  userId     Int       @map("user_id")
  target     String    // phone number or email
  targetType String    @map("target_type") // phone, email
  otpCode    String    @map("otp_code")
  expiresAt  DateTime  @map("expires_at")
  verified   Boolean   @default(false)
  attempts   Int       @default(0)
  createdAt  DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("otp_verifications")
}
